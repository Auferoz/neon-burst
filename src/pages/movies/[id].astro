---
import Layout from '../../layouts/Layout.astro';
import { env } from 'cloudflare:workers';
import { getMovieById } from '../../services/moviesService';

export const prerender = false;

const { id } = Astro.params;
const movie = await getMovieById(env.DB, Number(id));

if (!movie) {
	return Astro.redirect('/ListMovies');
}

function formatRuntime(minutes: number): string {
	if (!minutes) return '';
	const h = Math.floor(minutes / 60);
	const m = minutes % 60;
	if (h === 0) return `${m}m`;
	return m > 0 ? `${h}h ${m}m` : `${h}h`;
}

function ratingColor(rating: number): string {
	if (rating >= 7) return 'text-neon-green border-neon-green/30 bg-neon-green/10';
	if (rating >= 5) return 'text-neon-yellow border-neon-yellow/30 bg-neon-yellow/10';
	return 'text-neon-pink border-neon-pink/30 bg-neon-pink/10';
}

const genres = movie.genres ? movie.genres.split(',').map(s => s.trim()).filter(Boolean) : [];
const hasTrailer = !!movie.trailer;
const hasFanart = !!movie.fanart;
const hasMedia = hasTrailer || hasFanart || movie.videos.length > 0;
const heroImage = movie.fanart || movie.thumb || '';
---

<Layout title={`Neon Burst | ${movie.title}`}>
	<!-- Top bar -->
	<div class="flex items-center justify-between mb-6">
		<a
			href="/ListMovies"
			class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-neon-emerald transition-colors duration-200 group"
		>
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform duration-200">
				<polyline points="15 18 9 12 15 6" />
			</svg>
			Volver a la lista
		</a>
	</div>

	<!-- Hero section -->
	<div class="relative rounded-2xl overflow-hidden mb-8">
		{heroImage && (
			<div class="absolute inset-0 z-0">
				<img src={heroImage} alt="" class="w-full h-full object-cover object-top opacity-40" />
				<div class="absolute inset-0 bg-linear-to-t from-surface-0 via-surface-0/85 to-surface-0/50" />
			</div>
		)}

		<div class="relative z-10 flex flex-col sm:flex-row gap-6 p-6 sm:p-8">
			<!-- Poster -->
			<div class="shrink-0 self-center sm:self-start">
				{movie.poster ? (
					<img
						src={movie.poster}
						alt={movie.title}
						class="w-36 sm:w-44 rounded-xl object-cover aspect-[2/3] bg-surface-3 shadow-lg shadow-black/30"
						style={`view-transition-name: movie-poster-${movie.trakt_id};`}
						width="176"
						height="264"
					/>
				) : (
					<div class="w-36 sm:w-44 rounded-xl aspect-[2/3] bg-surface-3 flex items-center justify-center text-text-muted text-sm">
						?
					</div>
				)}
			</div>

			<!-- Info -->
			<div class="flex-1 min-w-0 flex flex-col justify-center">
				<!-- Title + Year + Certification -->
				<div class="flex flex-wrap items-start gap-3 mb-3">
					<h1 class="text-2xl sm:text-3xl font-bold text-text-primary leading-tight">{movie.title}</h1>
					<div class="flex items-center gap-2 shrink-0">
						{movie.year && (
							<span class="text-xs font-medium px-3 py-1 rounded-lg border text-neon-emerald border-neon-emerald/30 bg-neon-emerald/10">
								{movie.year}
							</span>
						)}
						{movie.certification && (
							<span class="text-xs font-medium px-3 py-1 rounded-lg border text-text-secondary border-border-default bg-surface-2">
								{movie.certification}
							</span>
						)}
					</div>
				</div>

				<!-- Tagline -->
				{movie.tagline && (
					<p class="text-sm text-text-secondary italic mb-3">{movie.tagline}</p>
				)}

				<!-- Meta row -->
				<div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-text-secondary mb-4">
					{movie.runtime > 0 && <span>{formatRuntime(movie.runtime)}</span>}
					{movie.runtime > 0 && movie.released && <span class="text-border-hover">&middot;</span>}
					{movie.released && <span>{movie.released}</span>}
					{(movie.runtime > 0 || movie.released) && movie.country && <span class="text-border-hover">&middot;</span>}
					{movie.country && <span class="uppercase">{movie.country}</span>}
					{movie.country && movie.language && <span class="text-border-hover">&middot;</span>}
					{movie.language && <span class="uppercase">{movie.language}</span>}
				</div>

				<!-- Genre tags -->
				{genres.length > 0 && (
					<div class="flex flex-wrap gap-1.5 mb-4">
						{genres.map((g: string) => (
							<span class="text-xs text-text-muted bg-surface-3/80 border border-border-default px-2.5 py-1 rounded-md capitalize">
								{g}
							</span>
						))}
					</div>
				)}

				<!-- Rating -->
				{movie.rating > 0 && (
					<div class="flex flex-wrap gap-3">
						<div class="flex items-center gap-2">
							<span class:list={[
								'inline-flex items-center justify-center h-9 rounded-lg text-sm font-bold border px-4',
								ratingColor(movie.rating)
							]}>
								{movie.rating.toFixed(1)}
							</span>
							<span class="text-xs text-text-muted">Trakt ({movie.votes.toLocaleString()} votos)</span>
						</div>
					</div>
				)}
			</div>
		</div>
	</div>

	<!-- Content grid -->
	<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
		<!-- Left column (2/3) -->
		<div class="lg:col-span-2 space-y-6">
			<!-- Sinopsis -->
			{movie.overview && (
				<div class="border border-border-default rounded-xl p-5 sm:p-6">
					<h2 class="text-sm font-semibold text-text-secondary uppercase tracking-wider mb-3">Sinopsis</h2>
					<div class="h-px bg-linear-to-r from-neon-emerald/30 via-neon-emerald/15 to-transparent mb-4"></div>
					<p class="text-sm text-text-secondary leading-relaxed whitespace-pre-line">{movie.overview}</p>
				</div>
			)}

			<!-- Media -->
			{hasMedia && (
				<div class="border border-border-default rounded-xl p-5 sm:p-6" id="media-card">
					<div class="flex gap-1 mb-4" role="tablist" aria-label="Media">
						{hasTrailer && (
							<button
								role="tab"
								aria-selected="true"
								aria-controls="panel-trailer"
								id="tab-trailer"
								class="media-tab active px-4 py-2 text-xs font-medium rounded-lg border transition-colors duration-200 cursor-pointer"
								data-tab="trailer"
							>
								<span class="flex items-center gap-1.5">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
										<polygon points="6 3 20 12 6 21 6 3" />
									</svg>
									Trailer
								</span>
							</button>
						)}
						{hasFanart && (
							<button
								role="tab"
								aria-selected={!hasTrailer ? 'true' : 'false'}
								aria-controls="panel-fanart"
								id="tab-fanart"
								class:list={['media-tab px-4 py-2 text-xs font-medium rounded-lg border transition-colors duration-200 cursor-pointer', !hasTrailer && 'active']}
								data-tab="fanart"
							>
								<span class="flex items-center gap-1.5">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
										<rect width="18" height="18" x="3" y="3" rx="2" ry="2" /><circle cx="9" cy="9" r="2" />
										<path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
									</svg>
									Fanart
								</span>
							</button>
						)}
						{movie.videos.length > 0 && (
							<button
								role="tab"
								aria-selected={!hasTrailer && !hasFanart ? 'true' : 'false'}
								aria-controls="panel-videos"
								id="tab-videos"
								class:list={['media-tab px-4 py-2 text-xs font-medium rounded-lg border transition-colors duration-200 cursor-pointer', !hasTrailer && !hasFanart && 'active']}
								data-tab="videos"
							>
								<span class="flex items-center gap-1.5">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
										<path d="m22 8-6 4 6 4V8Z" /><rect width="14" height="12" x="2" y="6" rx="2" ry="2" />
									</svg>
									Videos ({movie.videos.length})
								</span>
							</button>
						)}
					</div>

					<!-- Trailer panel -->
					{hasTrailer && (
						<div id="panel-trailer" role="tabpanel" aria-labelledby="tab-trailer" class="media-panel">
							<div class="relative aspect-video rounded-lg overflow-hidden bg-surface-3">
								<iframe
									src={`https://www.youtube.com/embed/${movie.trailer}`}
									title={`Trailer de ${movie.title}`}
									class="absolute inset-0 w-full h-full"
									allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
									allowfullscreen
									loading="lazy"
								/>
							</div>
						</div>
					)}

					<!-- Fanart panel -->
					{hasFanart && (
						<div id="panel-fanart" role="tabpanel" aria-labelledby="tab-fanart" class:list={['media-panel', hasTrailer && 'hidden']}>
							<img src={movie.fanart} alt={`Fanart de ${movie.title}`} class="w-full rounded-lg object-cover" loading="lazy" />
						</div>
					)}

					<!-- Videos panel -->
					{movie.videos.length > 0 && (
						<div id="panel-videos" role="tabpanel" aria-labelledby="tab-videos" class:list={['media-panel', (hasTrailer || hasFanart) && 'hidden']}>
							<div class="grid gap-3">
								{movie.videos.slice(0, 4).map((v) => (
									<div class="relative aspect-video rounded-lg overflow-hidden bg-surface-3">
										<iframe
											src={`https://www.youtube.com/embed/${v.key}`}
											title={v.name}
											class="absolute inset-0 w-full h-full"
											allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
											allowfullscreen
											loading="lazy"
										/>
									</div>
								))}
							</div>
						</div>
					)}
				</div>
			)}

			<!-- Cast -->
			{movie.cast.length > 0 && (
				<div class="border border-border-default rounded-xl p-5 sm:p-6">
					<h2 class="text-sm font-semibold text-text-secondary uppercase tracking-wider mb-3">Reparto</h2>
					<div class="h-px bg-linear-to-r from-neon-emerald/30 via-neon-emerald/15 to-transparent mb-4"></div>
					<div class="flex gap-3 overflow-x-auto pb-2 -mx-1 px-1 scrollbar-thin">
						{movie.cast.map((c) => (
							<div class="shrink-0 w-24 text-center">
								{c.headshot ? (
									<img
										src={c.headshot}
										alt={c.name}
										class="w-20 h-20 rounded-full object-cover mx-auto mb-2 bg-surface-3 border border-border-default"
										loading="lazy"
									/>
								) : (
									<div class="w-20 h-20 rounded-full bg-surface-3 border border-border-default mx-auto mb-2 flex items-center justify-center text-text-muted text-xl">
										?
									</div>
								)}
								<p class="text-xs font-medium text-text-primary leading-tight line-clamp-2">{c.name}</p>
								<p class="text-[10px] text-text-muted leading-tight line-clamp-1 mt-0.5">{c.character}</p>
							</div>
						))}
					</div>
				</div>
			)}
		</div>

		<!-- Right column (1/3) -->
		<div class="space-y-6">
			<!-- Detalles -->
			<div class="border border-border-default rounded-xl p-5">
				<h2 class="text-sm font-semibold text-text-secondary uppercase tracking-wider mb-3">Detalles</h2>
				<div class="h-px bg-linear-to-r from-neon-emerald/30 via-neon-emerald/15 to-transparent mb-4"></div>
				<dl class="space-y-3 text-sm">
					{movie.year && (
						<div class="flex justify-between">
							<dt class="text-text-muted">Año</dt>
							<dd class="text-text-primary font-medium">{movie.year}</dd>
						</div>
					)}
					{movie.runtime > 0 && (
						<div class="flex justify-between">
							<dt class="text-text-muted">Duración</dt>
							<dd class="text-text-primary font-medium">{formatRuntime(movie.runtime)}</dd>
						</div>
					)}
					{movie.certification && (
						<div class="flex justify-between">
							<dt class="text-text-muted">Clasificación</dt>
							<dd class="text-text-primary font-medium">{movie.certification}</dd>
						</div>
					)}
					{movie.country && (
						<div class="flex justify-between">
							<dt class="text-text-muted">País</dt>
							<dd class="text-text-primary font-medium uppercase">{movie.country}</dd>
						</div>
					)}
					{movie.language && (
						<div class="flex justify-between">
							<dt class="text-text-muted">Idioma</dt>
							<dd class="text-text-primary font-medium uppercase">{movie.language}</dd>
						</div>
					)}
					{movie.released && (
						<div class="flex justify-between">
							<dt class="text-text-muted">Estreno</dt>
							<dd class="text-text-primary font-medium">{movie.released}</dd>
						</div>
					)}
				</dl>
			</div>

			<!-- Enlaces -->
			<div class="border border-border-default rounded-xl p-5">
				<h2 class="text-sm font-semibold text-text-secondary uppercase tracking-wider mb-3">Enlaces</h2>
				<div class="h-px bg-linear-to-r from-neon-emerald/30 via-neon-emerald/15 to-transparent mb-4"></div>
				<div class="space-y-2">
					{movie.imdb_id && (
						<a href={`https://www.imdb.com/title/${movie.imdb_id}`} target="_blank" rel="noopener noreferrer"
							class="flex items-center gap-2 text-sm text-text-secondary hover:text-neon-yellow transition-colors">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" />
							</svg>
							IMDB
						</a>
					)}
					{movie.tmdb_id && (
						<a href={`https://www.themoviedb.org/movie/${movie.tmdb_id}`} target="_blank" rel="noopener noreferrer"
							class="flex items-center gap-2 text-sm text-text-secondary hover:text-neon-cyan transition-colors">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" />
							</svg>
							TMDB
						</a>
					)}
					<a href={`https://trakt.tv/movies/${movie.trakt_id}`} target="_blank" rel="noopener noreferrer"
						class="flex items-center gap-2 text-sm text-text-secondary hover:text-neon-pink transition-colors">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" />
						</svg>
						Trakt
					</a>
					{movie.homepage && (
						<a href={movie.homepage} target="_blank" rel="noopener noreferrer"
							class="flex items-center gap-2 text-sm text-text-secondary hover:text-neon-emerald transition-colors">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="12" cy="12" r="10" /><line x1="2" y1="12" x2="22" y2="12" /><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
							</svg>
							Sitio oficial
						</a>
					)}
				</div>
			</div>

			<!-- Post-créditos -->
			{(movie.after_credits || movie.during_credits) && (
				<div class="border border-border-default rounded-xl p-5">
					<h2 class="text-sm font-semibold text-text-secondary uppercase tracking-wider mb-3">Créditos</h2>
					<div class="h-px bg-linear-to-r from-neon-emerald/30 via-neon-emerald/15 to-transparent mb-4"></div>
					<div class="space-y-2 text-sm">
						<div class="flex items-center justify-between">
							<span class="text-text-muted">Durante créditos</span>
							{movie.during_credits ? (
								<span class="text-neon-green text-xs font-medium">Sí</span>
							) : (
								<span class="text-text-muted text-xs">No</span>
							)}
						</div>
						<div class="flex items-center justify-between">
							<span class="text-text-muted">Post-créditos</span>
							{movie.after_credits ? (
								<span class="text-neon-green text-xs font-medium">Sí</span>
							) : (
								<span class="text-text-muted text-xs">No</span>
							)}
						</div>
					</div>
				</div>
			)}
		</div>
	</div>
</Layout>

<style>
	.media-tab {
		color: var(--color-text-muted);
		border-color: var(--color-border-default);
		background: transparent;
	}
	.media-tab:hover {
		color: var(--color-text-secondary);
		border-color: var(--color-border-hover);
	}
	.media-tab.active {
		color: var(--color-neon-emerald);
		border-color: rgba(52, 211, 153, 0.3);
		background: rgba(52, 211, 153, 0.1);
	}
	.scrollbar-thin::-webkit-scrollbar {
		height: 4px;
	}
	.scrollbar-thin::-webkit-scrollbar-track {
		background: var(--color-surface-2);
		border-radius: 2px;
	}
	.scrollbar-thin::-webkit-scrollbar-thumb {
		background: var(--color-surface-4);
		border-radius: 2px;
	}
</style>

<script>
	document.addEventListener('astro:page-load', () => {
		const tabs = document.querySelectorAll<HTMLButtonElement>('.media-tab');
		const panels = document.querySelectorAll<HTMLElement>('.media-panel');

		tabs.forEach(tab => {
			tab.addEventListener('click', () => {
				const target = tab.dataset.tab;
				tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
				tab.classList.add('active');
				tab.setAttribute('aria-selected', 'true');
				panels.forEach(p => {
					if (p.id === `panel-${target}`) { p.classList.remove('hidden'); }
					else { p.classList.add('hidden'); }
				});
			});
		});
	});
</script>
