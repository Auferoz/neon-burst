---
import Layout from '../layouts/Layout.astro';
import NavCard from '../components/Astro/NavCard.astro';
import IconGamepad from '../components/Icons/IconGamepad.astro';
import IconLibrary from '../components/Icons/IconLibrary.astro';
import IconRocket from '../components/Icons/IconRocket.astro';
import IconTerminal from '../components/Icons/IconTerminal.astro';
import IconHome from '../components/Icons/IconHome.astro';
import IconFilm from '../components/Icons/IconFilm.astro';
import IconTv from '../components/Icons/IconTv.astro';
---

<Layout title="Neon Burst | Inicio">
	<section class="flex flex-col items-center gap-10 sm:gap-14 py-8 sm:py-16">

		<!-- Hero -->
		<div class="text-center space-y-4 px-2">
			<h1 class="text-3xl sm:text-4xl font-bold text-neon-blue neon-glow-blue leading-tight">
				NEON_BURST
			</h1>
			<p class="text-text-secondary text-sm sm:text-base leading-relaxed max-w-md mx-auto">
				Gaming tracker personal — juegos jugados, biblioteca Steam y próximos lanzamientos.
			</p>
		</div>

		<!-- Navigation cards -->
		<div class="grid grid-cols-2 sm:grid-cols-3 gap-4 sm:gap-5 w-full max-w-2xl">
			<NavCard href="/playedGames" title="Played Games" subtitle="Completados y más" accentColor="blue">
				<IconGamepad size={22} />
			</NavCard>

			<NavCard href="/mySteamGames" title="My Steam Games" subtitle="Biblioteca completa" accentColor="cyan">
				<IconLibrary size={22} />
			</NavCard>

			<NavCard href="/nextGames" title="Next Games" subtitle="Lanzamientos" accentColor="pink">
				<IconRocket size={22} />
			</NavCard>

			<NavCard href="/ListSeries" title="Series" subtitle="Lista de series" accentColor="indigo">
				<IconTv size={22} />
			</NavCard>

			<NavCard href="/ListMovies" title="Movies" subtitle="Lista de peliculas" accentColor="emerald">
				<IconFilm size={22} />
			</NavCard>

			<NavCard href="https://serviceswebporfolio.adesigns7.workers.dev/" title="Services Web" subtitle="Página de servicios web" accentColor="white">
				<IconHome size={22} />
			</NavCard>
		</div>
		

	</section>
</Layout>
