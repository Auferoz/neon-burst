---
interface Props {
	title: string;
	subtitle?: string;
	accentColor?: 'blue' | 'cyan' | 'pink' | 'emerald' | 'indigo';
}

const { title, subtitle, accentColor = 'blue' } = Astro.props;

const colorMap = {
	blue: { text: 'text-neon-blue', glow: 'neon-glow-blue', dot: 'bg-neon-blue' },
	cyan: { text: 'text-neon-cyan', glow: 'neon-glow-cyan', dot: 'bg-neon-cyan' },
	pink: { text: 'text-neon-pink', glow: 'neon-glow-pink', dot: 'bg-neon-pink' },
	emerald: { text: 'text-neon-emerald', glow: 'neon-glow-emerald', dot: 'bg-neon-emerald' },
	indigo: { text: 'text-neon-indigo', glow: 'neon-glow-indigo', dot: 'bg-neon-indigo' },
};

const colors = colorMap[accentColor];
---

<div class="mb-8 sm:mb-10">
	<div class="flex items-center gap-3 mb-2">
		<h1 class={`text-xl sm:text-2xl font-bold ${colors.text} ${colors.glow} leading-tight`}>
			{title}
		</h1>
	</div>
	{subtitle && (
		<p class="text-text-secondary text-sm leading-relaxed mt-1">{subtitle}</p>
	)}
</div>
